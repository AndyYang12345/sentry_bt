# - 0 比赛未开始(可无限持续，期间time值为0)
# - 1 比赛准备阶段(持续10s)
# - 2 比赛进行阶段(一般持续420s，可因为一方胜利提前结束)
uint8 game_period

# 当前比赛阶段剩余时间 0-420
uint16 time

# sentry血量 0-400
uint16 hp_sentry

# sentry防御增益 0-100
# 该值为x时，sentry可减免x%受到的伤害，例如为50时，sentry受到原本100的伤害，只会扣除 100 × (1 - 50%) = 50 的血
uint8 defence_buff

# 己方队伍装甲板颜色 0 红色 1 蓝色
uint8 color

# sentry剩余子弹量 0 - uint16 max值
uint16 ammo

# 己方前哨站血量 0-1000
uint16 hp_outpost

# 己方基地血量 0-5000
uint16 hp_base

# 敌方单位血量
# 该消息数据为uint16数组，与发布者正确通信时会发布长度为8的数组
# 数组0-7索引位置的值依次对应敌方1-8号单位的血量:
# 1. 1号机器人(0-250, 1001)
# 2. 2号机器人(0-200, 1001)
# 3. 3号机器人(0-200, 1001)
# 4. 4号机器人(0-200, 1001)
# 5. 5号机器人(0-200, 1001)
# 6. 前哨站(6号)(0-1000)
# 7. 基地(7号)(0-5000)
# 8. 8号机器人(0-400, 1001)
# 以上单位中的地面单位，当其血量为1001时，表示其处于无敌状态，不应该被指定为自瞄击打目标
uint16[] hp_enemy

# 敌方机器人位置
# 该消息数据为float32数组，与发布者正确通信时会发布长度为12的数组
# 数组0-11索引位置的值依次对应我方雷达系统侦查到的敌方1,2,3,4,5,8号机器人的位置
# 从数组头部开始每相邻两个量分别表示一个机器人在RM地图中的x,y坐标:
# radar_data[0]、radar_data[1]  -> 敌方1号机器人的x、y坐标
# radar_data[2]、radar_data[3]  -> 敌方2号机器人的x、y坐标
# radar_data[4]、radar_data[5]  -> 敌方3号机器人的x、y坐标
# radar_data[6]、radar_data[7]  -> 敌方4号机器人的x、y坐标
# radar_data[8]、radar_data[9]  -> 敌方5号机器人的x、y坐标
# radar_data[10]、radar_data[11] -> 敌方8号机器人的x、y坐标
# 雷达系统未识别出相应目标时会发送0.0作为默认值
float32[] radar_data