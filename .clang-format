# 基于 Google 风格
BasedOnStyle: Google

# 缩进宽度（Google默认2空格，改为4空格更清晰）
IndentWidth: 4
ColumnLimit: 100

# 指针对齐风格（左对齐）
PointerAlignment: Left

# 大括号风格
BreakBeforeBraces: Attach

# 注释对齐
AlignTrailingComments: true

# include 排序
SortIncludes: true

# 连续赋值对齐（可选）
AlignConsecutiveAssignments: false

# 语言标准
Standard: c++17
